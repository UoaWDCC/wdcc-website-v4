{
    "name": "wdcc-website-v4",
    "version": "0.0.0-beta",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev --turbo",
        "build": "next build",
        "build:analyze": "cross-env ANALYZE=true next build",
        "build:turbo": "next build --turbo",
        "start": "next start",
        "deploy:staging": "fly deploy --config fly.staging.toml",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:no-cache": "eslint . --no-cache",
        "format": "prettier . --write",
        "l": "pnpm run format && pnpm run lint",
        "lint:ci": "prettier . --check && eslint .",
        "i:ci": "pnpm install --frozen-lockfile",
        "list": "pnpm list --depth 0",
        "clear:next": "rimraf .next",
        "clear:modules": "rimraf node_modules",
        "nuke": "rimraf .next && rimraf node_modules",
        "typegen": "payload generate:types"
    },
    "dependencies": {
        "@next/bundle-analyzer": "^15.5.9",
        "@payloadcms/db-postgres": "3.77.0",
        "@payloadcms/next": "3.77.0",
        "@payloadcms/richtext-lexical": "3.77.0",
        "@payloadcms/storage-s3": "3.77.0",
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "9.1.2",
        "@rive-app/react-canvas": "^4.25.3",
        "clsx": "^2.1.1",
        "cross-spawn": "^7.0.6",
        "glslify-loader": "^2.0.0",
        "graphql": "^16.12.0",
        "motion": "^12.24.11",
        "next": "16.1.6",
        "payload": "3.77.0",
        "raw-loader": "^4.0.2",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "sharp": "^0.34.5",
        "tailwind-merge": "^2.6.0",
        "tailwind-variants": "^0.3.1",
        "three": "0.171.0",
        "tunnel-rat": "^0.1.2"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.3",
        "@eslint/js": "^9.39.2",
        "@flydotio/dockerfile": "^0.5.9",
        "@tailwindcss/postcss": "^4.1.18",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/node": "^22.19.3",
        "@types/react": "^18.3.27",
        "@types/react-dom": "^18.3.7",
        "@types/three": "0.170.0",
        "@typescript-eslint/eslint-plugin": "^8.52.0",
        "@typescript-eslint/parser": "^8.52.0",
        "cross-env": "^7.0.3",
        "eslint": "^9.39.2",
        "eslint-config-next": "15.3.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-unused-imports": "^4.3.0",
        "lil-gui": "^0.20.0",
        "nanoid": "^5.1.6",
        "postcss": "^8.5.6",
        "prettier": "^3.7.4",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "rimraf": "^6.1.2",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.52.0"
    },
    "volta": {
        "node": "20.18.1",
        "pnpm": "10.6.1"
    },
    "dockerfile": {
        "secrets": [
            "DATABASE_URI",
            "PAYLOAD_SECRET",
            "S3_BUCKET",
            "S3_ACCESS_KEY_ID",
            "S3_SECRET_ACCESS_KEY",
            "S3_REGION"
        ]
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "sharp"
        ],
        "overrides": {
            "minimatch": ">=10.2.3",
            "@isaacs/brace-expansion": ">=5.0.1",
            "esbuild": ">=0.25.0",
            "diff": ">=5.2.2",
            "fast-xml-parser": ">=5.3.8"
        }
    }
}
